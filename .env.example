# =========================================================================
# Microsoft Fabric Smart Banking AI-Powered - Local Environment Configuration
# =========================================================================
# Copy this file to '.env' and fill in your custom credentials and endpoints.
# Ensure that '.env' is never committed to GitHub (it is ignored by .gitignore).

# 1. Azure Service Principal Credentials (for Azure CLI / Fabric authentications)
AZURE_TENANT_ID="YOUR_AZURE_TENANT_ID"
AZURE_CLIENT_ID="YOUR_AZURE_CLIENT_ID"
AZURE_CLIENT_SECRET="YOUR_AZURE_CLIENT_SECRET"

# 2. Fabric Real-Time Intelligence Connection Strings
# Custom Eventstream Endpoint string containing connection tokens (SharedAccessKey)
EVENTSTREAM_CUSTOM_ENDPOINT="Endpoint=sb://<your-servicebus-namespace>.servicebus.windows.net/;SharedAccessKeyName=<key-name>;SharedAccessKey=<your-shared-access-key>;EntityPath=<your-entity-path>"

# 3. KQL Database Query Endpoint URI
KQL_QUERY_URI="https://<your-eventhouse-id>.<location>.kusto.fabric.microsoft.com"

# 4. OpenAI / Azure OpenAI Configuration (for fraud explanations and agent reasoning)
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
